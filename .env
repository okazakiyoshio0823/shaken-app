# Environment Variables

# JWT Secret
JWT_SECRET=dev_secret_change_in_production

# Database (if using PostgreSQL in production)
# DB_HOST=localhost
# DB_NAME=mechaniq_db
# DB_USER=postgres
# DB_PASS=password

# Email Configuration
EMAIL_MODE=development
# EMAIL_MODE=production  # 本番環境で切り替え

# SMTP Settings (本番環境用)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Mechaniq <noreply@mechaniq.com>

# Server
PORT=5000
